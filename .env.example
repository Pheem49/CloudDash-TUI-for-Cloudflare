# CloudDash Configuration
# Copy this file to .env and fill in your credentials

# Your Cloudflare API Token
# Get it from: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: D1:Edit, R2:Edit, Account Settings:Read
CLOUDFLARE_API_TOKEN=your_api_token_here

# Your Cloudflare Account ID
# Find it in the URL after logging in: https://dash.cloudflare.com/[YOUR_ACCOUNT_ID]
# Or go to: https://dash.cloudflare.com/profile/account-home
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
